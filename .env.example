# ── Data source ─────────────────────────────────────────────────────────────
# Leave EVERYTHING unset to run on the embedded Postgres (PGlite) — zero setup.
#
# For a Vercel / hosted deployment, set DATABASE_URL to a hosted Postgres
# connection string (Supabase, Neon, RDS, …). Migrations in supabase/migrations
# must already be applied to that database.
# DATABASE_URL=postgresql://user:password@host:5432/dbname
#
# Optional: PGSSL=disable to turn off TLS (local Postgres); PGPOOL_MAX=5 pool size.
# Optional: PGLITE_DATA_DIR=./.pglite-data to move the embedded data directory.

# ── Auth ────────────────────────────────────────────────────────────────────
# Session-signing secret. REQUIRED for any real deployment (a hosted DB or
# platform): without it, sessions are signed with a public built-in key and can
# be forged, and the app refuses to start. Generate one, e.g.:
#   openssl rand -base64 48
# AUTH_SECRET=replace-with-a-long-random-value
